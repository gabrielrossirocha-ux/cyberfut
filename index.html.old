<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Futsal Sorteio de Times</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>⚽ Sorteio de Times de Futsal</h1>
        <p class="subtitulo">Cadastre até 12 jogadores e distribua posições automaticamente</p>

        <div id="mensagem" class="mensagem" style="display: none;"></div>

        <div class="grid-2colunas">
            <!-- Área de cadastro -->
            <div class="card">
                <h2>📝 Cadastrar Jogador</h2>
                <form id="formJogador">
                    <input type="text" id="nome" placeholder="Nome do jogador" required maxlength="30">
                    
                    <select id="posicao" required>
                        <option value="">Selecione a posição</option>
                        <option value="Goleiro">Goleiro</option>
                        <option value="Fixo">Fixo</option>
                        <option value="Ala Esquerda">Ala Esquerda</option>
                        <option value="Ala Direita">Ala Direita</option>
                        <option value="Pivô">Pivô</option>
                    </select>
                    
                    <div class="caracteristicas-area">
                        <label class="label-caracteristicas">💪 Características (selecione 2 ou 3):</label>
                        <div id="habilidadesContainer" class="habilidades-grid">
                            <!-- As checkboxes serão inseridas via JavaScript -->
                        </div>
                        <small id="contadorCaracteristicas" class="contador-caracteristicas">0 selecionadas (mínimo 2, máximo 3)</small>
                    </div>
                    
                    <button type="submit" class="btn-vermelho">➕ Adicionar Jogador</button>
                </form>

                <div class="contador">
                    📊 Jogadores cadastrados: <span id="totalJogadores">0</span> / 12
                </div>

                <button id="btnResetar" class="btn-preto">🗑️ Resetar tudo</button>
            </div>

            <!-- Lista de jogadores cadastrados -->
            <div class="card">
                <h2>👥 Jogadores Cadastrados</h2>
                <div id="listaJogadores">
                    <p class="vazio">Nenhum jogador ainda. Adicione acima.</p>
                </div>
            </div>
        </div>

        <!-- Botão de sorteio -->
        <div class="sorteio-area">
            <button id="btnSortear" class="btn-sortear">🎲 SORTEAR TIMES</button>
        </div>

        <!-- Exibição dos times sorteados -->
        <div id="timesContainer" style="display: none;">
            <div class="grid-2colunas times">
                <div class="card time-vermelho">
                    <h2>🔴 TIME VERMELHO</h2>
                    <ul id="timeALista" class="lista-times"></ul>
                </div>

                <div class="card time-branco">
                    <h2>⚪ TIME BRANCO</h2>
                    <ul id="timeBLista" class="lista-times"></ul>
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
